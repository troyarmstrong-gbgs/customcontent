# ─────────────────────────────────────────────────
#  TEG Content Request Portal — Environment Config
#  Copy this file to ".env" and fill in your values
# ─────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# ── Email Notification Settings ──────────────────
# The email address that will RECEIVE submission notifications
NOTIFY_EMAIL=troy.armstrong@theescapegame.com

# SMTP credentials for SENDING email notifications
# Gmail example: use an App Password (not your regular password)
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
#   2. Generate a password for "Mail" and paste it below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-app-password-here

# "From" name shown in notification emails
SMTP_FROM_NAME=TEG Content Request Portal

# ── Hub Access (Optional) ─────────────────────────
# Set a password to protect the /hub admin page
# Leave blank to disable password protection
HUB_PASSWORD=
